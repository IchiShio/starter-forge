---
const testimonials = [
  {
    quote: 'StarterForge saved me at least a week of setup time. The dark mode and blog were ready to go from day one.',
    name: 'Sarah Chen',
    role: 'Indie Hacker',
    gradient: 'from-primary-400 to-blue-500',
  },
  {
    quote: 'The code quality is exceptional. Clean, well-structured, and easy to customize. Worth every penny.',
    name: 'Marcus Johnson',
    role: 'Full-Stack Developer',
    gradient: 'from-purple-400 to-pink-500',
  },
  {
    quote: 'I launched my SaaS landing page in under 2 hours. The Tailwind v4 setup with Astro 5 just works perfectly.',
    name: 'Emily Rodriguez',
    role: 'Startup Founder',
    gradient: 'from-emerald-400 to-teal-500',
  },
];
---

<section class="py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary-600 dark:text-primary-400">Testimonials</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
        Loved by developers
      </h2>
    </div>

    <!-- Testimonial cards -->
    <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t) => (
        <div class="flex flex-col rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
          <!-- Quote -->
          <div class="mb-6 flex-1">
            <svg class="mb-3 h-8 w-8 text-primary-200 dark:text-primary-800" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z" />
            </svg>
            <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-300">
              "{t.quote}"
            </p>
          </div>

          <!-- Author -->
          <div class="flex items-center gap-3 border-t border-gray-100 pt-4 dark:border-gray-800">
            <div class={`h-10 w-10 shrink-0 rounded-full bg-gradient-to-br ${t.gradient}`}></div>
            <div>
              <p class="text-sm font-semibold text-gray-900 dark:text-white">{t.name}</p>
              <p class="text-xs text-gray-500 dark:text-gray-400">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
