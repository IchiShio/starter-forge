---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog" description="Articles, tutorials, and updates from the StarterForge team.">
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white">Blog</h1>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-300">
          Guides, tutorials, and updates to help you get the most out of StarterForge.
        </p>
      </div>

      <!-- Posts -->
      <div class="space-y-8">
        {posts.map((post) => (
          <article class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all duration-200 hover:border-primary-200 hover:shadow-md dark:border-gray-800 dark:bg-gray-900 dark:hover:border-primary-800">
            <a href={`/blog/${post.id}`} class="block">
              <div class="flex flex-wrap items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                {post.data.tags.length > 0 && (
                  <>
                    <span aria-hidden="true">&middot;</span>
                    <div class="flex flex-wrap gap-1">
                      {post.data.tags.map((tag) => (
                        <span class="rounded-full bg-primary-50 px-2.5 py-0.5 text-xs font-medium text-primary-700 dark:bg-primary-950/50 dark:text-primary-300">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </>
                )}
              </div>
              <h2 class="mt-3 text-xl font-semibold text-gray-900 transition-colors group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400">
                {post.data.title}
              </h2>
              <p class="mt-2 text-gray-600 dark:text-gray-400">
                {post.data.description}
              </p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary-600 dark:text-primary-400">
                Read more
                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </span>
            </a>
          </article>
        ))}
      </div>

      {posts.length === 0 && (
        <p class="text-center text-gray-500 dark:text-gray-400">No posts yet. Check back soon!</p>
      )}
    </div>
  </section>
</Layout>
